{
  "name": "nvidia-contact-eds-poc",
  "version": "1.0.0",
  "description": "NVIDIA Contact page POC built with Adobe Edge Delivery Services (EDS) patterns",
  "type": "module",
  "scripts": {
    "start": "npx serve . --listen 3001",
    "stop": "npx kill-port 3001",
    "build:json": "node scripts/build-json.js",
    "build:kui": "esbuild scripts/kui/foundations-react.entry.js --bundle --format=esm --outfile=scripts/kui/foundations-react.bundle.js --external:react --external:react-dom --external:react/jsx-runtime --external:react-dom/client --alias:react-compiler-runtime=./scripts/kui/react-compiler-runtime.shim.js",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"blocks/**/*.css\" \"styles/*.css\"",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:fix": "npm run lint:js -- --fix && npm run lint:css -- --fix",
    "prepare": "husky",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@adobe/aem-cli": "^16.0.0",
    "@babel/eslint-parser": "7.29.7",
    "@playwright/test": "^1.60.0",
    "esbuild": "^0.28.1",
    "eslint": "8.57.1",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-plugin-import": "2.32.0",
    "husky": "^9.0.0",
    "kill-port": "^2.0.0",
    "serve": "^14.0.0",
    "stylelint": "17.12.0",
    "stylelint-config-standard": "40.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@kui/foundations-css": "^1.1.2",
    "@kui/foundations-react": "^1.1.2"
  }
}
